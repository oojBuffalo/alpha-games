# --- Claude Code / session state (never version-controlled) ---
.claude/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.coverage
htmlcov/

# --- ML / training artifacts (large or reproducible; keep out of git) ---
# checkpoints, replay buffers, self-play shards, run logs, profiles.
# (Precomputed golden tables are intentionally NOT ignored — commit those.)
checkpoints/
runs/
wandb/
*.pt
*.ckpt
replay/
*.replay
*.tfevents.*

# --- OS cruft ---
.DS_Store
Thumbs.db
